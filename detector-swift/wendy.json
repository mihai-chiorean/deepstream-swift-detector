{
    "appId": "sh.wendy.examples.deepstream-detector-swift",
    "version": "1.0.0",
    "language": "swift",
    "swift": {
        "baseImage": "EDIT THIS — see detector-swift/README.md for what to point at",
        "resources": [
            "streams.json:/app/streams.json",
            "labels.txt:/app/labels.txt",
            "yolo26n.onnx:/app/yolo26n.onnx",
            "yolo26n_b2_fp16.engine:/app/yolo26n_b2_fp16.engine",
            "ffmpeg:/app/ffmpeg",
            "libnvdsparsebbox_yolo26.so:/app/lib/libnvdsparsebbox_yolo26.so"
        ]
    },
    "entitlements": [
        {"type": "gpu"},
        {"type": "network", "mode": "host"},
        {"type": "persist", "name": "detector-cache", "path": "/var/cache/detector"}
    ]
}
